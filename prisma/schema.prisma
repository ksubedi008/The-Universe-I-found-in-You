generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model Message {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
}

model Memory {
  id          String   @id @default(uuid())
  title       String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
}
